{
  "colegio": "Bachiller en Educación Media",
  "nivel": "Séptimo",
  "areas": [
    {
      "id": 1,
      "nombre": "Números",
      "quices": [
        {
          "id": 1,
          "titulo": "Sumas Básicas",
          "preguntas": [
            {
              "template": "¿Cuánto es {{a}} + {{b}}?",
              "opciones": ["{{a}}+{{b}}", "{{a}}+{{b}}+1", "{{a}}+{{b}}-1", "{{a}}*{{b}}"],
              "respuesta_correcta": 0,
              "variables": {
                "a": {"min": 10, "max": 50},
                "b": {"min": 10, "max": 50}
              }
            },
            {
              "template": "¿Cuánto es {{x}} - {{y}}?",
              "opciones": ["{{x}}-{{y}}", "{{x}}-{{y}}+1", "{{x}}+{{y}}", "{{y}}-{{x}}"],
              "respuesta_correcta": 0,
              "variables": {
                "x": {"min": 50, "max": 100},
                "y": {"min": 10, "max": 40}
              }
            },
            {
              "template": "¿Cuánto es {{m}} × {{n}}?",
              "opciones": ["{{m}}*{{n}}", "{{m}}*{{n}}+1", "{{m}}+{{n}}", "{{m}}*{{n}}-1"],
              "respuesta_correcta": 0,
              "variables": {
                "m": {"min": 5, "max": 12},
                "n": {"min": 5, "max": 12}
              }
            }
          ]
        },
        {
          "id": 2,
          "titulo": "Divisiones",
          "preguntas": [
            {
              "template": "¿Cuánto es {{a}} ÷ {{b}}?",
              "opciones": ["{{a}}/{{b}}", "{{a}}/{{b}}+1", "{{a}}*{{b}}", "{{a}}-{{b}}"],
              "respuesta_correcta": 0,
              "variables": {
                "a": {"min": 20, "max": 100},
                "b": {"min": 2, "max": 10}
              }
            },
            {
              "template": "Si tienes {{cantidad}} manzanas y las divides entre {{personas}} personas, ¿cuántas manzanas le toca a cada uno?",
              "opciones": ["{{cantidad}}/{{personas}}", "{{cantidad}}-{{personas}}", "{{cantidad}}*{{personas}}", "{{cantidad}}+{{personas}}"],
              "respuesta_correcta": 0,
              "variables": {
                "cantidad": {"min": 20, "max": 50},
                "personas": {"min": 2, "max": 5}
              }
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "nombre": "Geometría",
      "quices": [
        {
          "id": 1,
          "titulo": "Áreas de Figuras",
          "preguntas": [
            {
              "template": "¿Cuál es el área de un rectángulo con base {{b}} y altura {{h}}?",
              "opciones": ["{{b}}*{{h}}", "{{b}}*{{h}}/2", "{{b}}+{{h}}", "2*{{b}}+2*{{h}}"],
              "respuesta_correcta": 0,
              "variables": {
                "b": {"min": 3, "max": 10},
                "h": {"min": 3, "max": 10}
              }
            },
            {
              "template": "¿Cuál es el área de un triángulo con base {{base}} y altura {{altura}}?",
              "opciones": ["{{base}}*{{altura}}/2", "{{base}}*{{altura}}", "{{base}}+{{altura}}", "{{base}}*{{altura}}/4"],
              "respuesta_correcta": 0,
              "variables": {
                "base": {"min": 4, "max": 12},
                "altura": {"min": 3, "max": 10}
              }
            }
          ]
        },
        {
          "id": 2,
          "titulo": "Perímetros",
          "preguntas": [
            {
              "template": "¿Cuál es el perímetro de un cuadrado con lado {{lado}}?",
              "opciones": ["4*{{lado}}", "{{lado}}*{{lado}}", "2*{{lado}}", "{{lado}}+{{lado}}"],
              "respuesta_correcta": 0,
              "variables": {
                "lado": {"min": 2, "max": 10}
              }
            },
            {
              "template": "¿Cuál es el perímetro de un rectángulo con largo {{largo}} y ancho {{ancho}}?",
              "opciones": ["2*{{largo}}+2*{{ancho}}", "{{largo}}*{{ancho}}", "{{largo}}+{{ancho}}", "{{largo}}*{{ancho}}/2"],
              "respuesta_correcta": 0,
              "variables": {
                "largo": {"min": 4, "max": 10},
                "ancho": {"min": 2, "max": 8}
              }
            }
          ]
        }
      ]
    },
    {
      "id": 3,
      "nombre": "Relaciones y Álgebra",
      "quices": [
        {
          "id": 1,
          "titulo": "Ecuaciones Simples",
          "preguntas": [
            {
              "template": "Si x + {{a}} = {{suma}}, ¿cuál es el valor de x?",
              "opciones": ["{{suma}}-{{a}}", "{{suma}}+{{a}}", "{{suma}}*{{a}}", "{{suma}}/{{a}}"],
              "respuesta_correcta": 0,
              "variables": {
                "a": {"min": 5, "max": 20},
                "suma": {"min": 20, "max": 50}
              }
            }
          ]
        }
      ]
    },
    {
      "id": 4,
      "nombre": "Estadística",
      "quices": [
        {
          "id": 1,
          "titulo": "Promedio",
          "preguntas": [
            {
              "template": "¿Cuál es el promedio de {{n1}}, {{n2}} y {{n3}}?",
              "opciones": ["({{n1}}+{{n2}}+{{n3}})/3", "{{n1}}+{{n2}}+{{n3}}", "({{n1}}+{{n2}})/2", "{{n1}}*{{n2}}*{{n3}}"],
              "respuesta_correcta": 0,
              "variables": {
                "n1": {"min": 10, "max": 30},
                "n2": {"min": 10, "max": 30},
                "n3": {"min": 10, "max": 30}
              }
            }
          ]
        }
      ]
    }
  ]
}
