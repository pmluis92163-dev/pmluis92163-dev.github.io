{
  "colegio": "Bachiller en Educación Media",
  "nivel": "Octavo",
  "areas": [
    {
      "id": 1,
      "nombre": "Números",
      "quices": [
        {
          "id": 1,
          "titulo": "Operaciones con Decimales",
          "preguntas": [
            {
              "template": "¿Cuánto es {{a}} + {{b}}?",
              "opciones": ["{{a}}+{{b}}", "{{a}}+{{b}}+0.1", "{{a}}-{{b}}", "{{a}}*{{b}}"],
              "respuesta_correcta": 0,
              "variables": {
                "a": {"min": 10, "max": 50},
                "b": {"min": 5, "max": 30}
              }
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "nombre": "Geometría",
      "quices": [
        {
          "id": 1,
          "titulo": "Volumen de Sólidos",
          "preguntas": [
            {
              "template": "¿Cuál es el volumen de un cubo con lado {{lado}}?",
              "opciones": ["{{lado}}*{{lado}}*{{lado}}", "{{lado}}*{{lado}}", "{{lado}}*6", "{{lado}}*4"],
              "respuesta_correcta": 0,
              "variables": {
                "lado": {"min": 2, "max": 5}
              }
            },
            {
              "template": "¿Cuál es el volumen de un prisma rectangular con largo {{l}}, ancho {{a}} y alto {{h}}?",
              "opciones": ["{{l}}*{{a}}*{{h}}", "{{l}}*{{a}}", "{{l}}+{{a}}+{{h}}", "{{l}}*{{a}}*{{h}}/2"],
              "respuesta_correcta": 0,
              "variables": {
                "l": {"min": 3, "max": 8},
                "a": {"min": 2, "max": 6},
                "h": {"min": 2, "max": 5}
              }
            }
          ]
        }
      ]
    },
    {
      "id": 3,
      "nombre": "Relaciones y Álgebra",
      "quices": [
        {
          "id": 1,
          "titulo": "Factorización",
          "preguntas": [
            {
              "template": "Si tienes la expresión {{a}}x + {{b}}, ¿cuál es el máximo común divisor?",
              "opciones": ["{{a}}", "x", "{{b}}", "{{a}}+{{b}}"],
              "respuesta_correcta": 0,
              "variables": {
                "a": {"min": 2, "max": 10},
                "b": {"min": 5, "max": 20}
              }
            }
          ]
        }
      ]
    },
    {
      "id": 4,
      "nombre": "Estadística",
      "quices": [
        {
          "id": 1,
          "titulo": "Medidas Estadísticas",
          "preguntas": [
            {
              "template": "En un conjunto de datos: {{n1}}, {{n2}}, {{n3}}, {{n4}}, ¿cuál es la mediana?",
              "opciones": ["({{n2}}+{{n3}})/2", "{{n2}}", "({{n1}}+{{n4}})/2", "{{n1}}+{{n2}}+{{n3}}+{{n4}}"],
              "respuesta_correcta": 0,
              "variables": {
                "n1": {"min": 5, "max": 15},
                "n2": {"min": 15, "max": 25},
                "n3": {"min": 25, "max": 35},
                "n4": {"min": 35, "max": 50}
              }
            }
          ]
        }
      ]
    },
    {
      "id": 5,
      "nombre": "Probabilidad",
      "quices": [
        {
          "id": 1,
          "titulo": "Probabilidad Básica",
          "preguntas": [
            {
              "template": "Si lanzas un dado, ¿cuál es la probabilidad de obtener un número mayor a {{num}}?",
              "opciones": ["(6-{{num}})/6", "{{num}}/6", "1/2", "1"],
              "respuesta_correcta": 0,
              "variables": {
                "num": {"min": 1, "max": 4}
              }
            }
          ]
        }
      ]
    }
  ]
}
